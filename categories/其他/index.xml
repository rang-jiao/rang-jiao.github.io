&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#7f7f7f"&gt; 3&lt;/span&gt;&lt;span&gt;&lt;span style="color:#fb660a;font-weight:bold"&gt;import&lt;/span&gt;&lt;span style="color:#888"&gt; &lt;/span&gt;&lt;span style="color:#0086d2"&gt;&amp;#34;fmt&amp;#34;&lt;/span&gt;&lt;span style="color:#888"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#7f7f7f"&gt; 4&lt;/span&gt;&lt;span&gt;&lt;span style="color:#888"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#7f7f7f"&gt; 5&lt;/span&gt;&lt;span&gt;&lt;span style="color:#fb660a;font-weight:bold"&gt;func&lt;/span&gt;&lt;span style="color:#888"&gt; &lt;/span&gt;&lt;span style="color:#ff0086;font-weight:bold"&gt;main&lt;/span&gt;()&lt;span style="color:#888"&gt; &lt;/span&gt;{&lt;span style="color:#888"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#7f7f7f"&gt; 6&lt;/span&gt;&lt;span&gt;&lt;span style="color:#888"&gt; &lt;/span&gt;fmt.&lt;span style="color:#ff0086;font-weight:bold"&gt;Println&lt;/span&gt;(&lt;span style="color:#0086d2"&gt;&amp;#34;Hello, Hugo!&amp;#34;&lt;/span&gt;)&lt;span style="color:#888"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#7f7f7f"&gt; 7&lt;/span&gt;&lt;span&gt;&lt;span style="color:#888"&gt; &lt;/span&gt;&lt;span style="color:#080;background-color:#0f140f;font-style:italic"&gt;// 计算平方&lt;/span&gt;&lt;span style="color:#888"&gt;
